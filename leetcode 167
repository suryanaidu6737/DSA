class Solution {
    public int[] twoSum(int[] arr, int target) {
        int n=arr.length;
        HashMap<Integer,Integer> map=new HashMap<>();
        int[] out=new int[2];
        for(int i=0;i<n;i++){
            int val=target-arr[i];
            if(map.containsKey(val)){
                out[1]=i+1;
                out[0]=(map.get(val))+1;
                break;
            }else{
                map.put(arr[i],i);
            }
        }
        return out;

    }
}
