class Solution {
    public boolean isValid(String s) {
        Stack<Character> ch=new Stack<>(); 
        char[] arr=s.toCharArray();
        for(char c:arr){
            if(c=='('||c=='['||c=='{') ch.push(c);
            else{
                if(ch.isEmpty())return false;
                char top=ch.pop();
                if((c==')'&& top!='(')||(c==']'&& top!='[')||(c=='}'&& top!='{'))
                return false;
            }
        }
        return ch.isEmpty();
    }
}
